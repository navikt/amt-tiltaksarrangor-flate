{
  "name": "amt-tiltaksarrangor-flate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build:gh-pages": "NODE_ENV=development vite build --mode demo --base=/amt-tiltaksarrangor-flate/ && cpy index.html build --cwd=build --rename=404.html",
    "test": "vitest",
    "lint": "eslint --max-warnings=0 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'src/**/*.{ts,tsx,js}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "cy:clear": "cypress cache clear"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write src/**/*"
    ]
  },
  "dependencies": {
    "@navikt/aksel-icons": "^8.12.1",
    "@navikt/ds-css": "^8.12.1",
    "@navikt/ds-react": "^8.12.1",
    "@navikt/nav-dekoratoren-moduler": "^4.2.2",
    "@sentry/react": "^10.57.0",
    "@sentry/tracing": "^7.120.4",
    "@types/react": "^19.2.17",
    "@types/react-collapse": "^5.0.4",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "axios": "^1.17.0",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@navikt/aksel": "^8.12.1",
    "@vitejs/plugin-react": "^6.0.2",
    "cpy-cli": "^7.0.0",
    "cypress": "^15.17.0",
    "cypress-axe": "^1.7.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "table": "^6.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "packageManager": "pnpm@11.8.0"
}