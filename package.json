{
  "name": "amt-tiltaksarrangor-flate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build:gh-pages": "NODE_ENV=development vite build --mode demo --base=/amt-tiltaksarrangor-flate/ && cpy index.html build --cwd=build --rename=404.html",
    "test": "vitest",
    "lint": "eslint --max-warnings=0 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'src/**/*.{ts,tsx,js}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "cy:clear": "cypress cache clear"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write src/**/*"
    ]
  },
  "dependencies": {
    "@navikt/aksel-icons": "^8.9.1",
    "@navikt/ds-css": "^8.9.1",
    "@navikt/ds-react": "^8.9.1",
    "@navikt/nav-dekoratoren-moduler": "^3.7.1",
    "@sentry/react": "^10.49.0",
    "@sentry/tracing": "^7.120.4",
    "@types/react": "^19.2.14",
    "@types/react-collapse": "^5.0.4",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "axios": "^1.15.1",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.20",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "typescript": "^6.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@navikt/aksel": "^8.9.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cpy-cli": "^7.0.0",
    "cypress": "^15.14.0",
    "cypress-axe": "^1.7.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.4",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "table": "^6.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "flatted@<3.4.1": ">=3.4.2",
      "picomatch@<4.0.4": ">=4.0.4",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "axios@<1.15.0": ">=1.15.0",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0"
    }
  }
}